# True aliases only. Function-style helpers live in fn_*.zsh.

alias vim="nvim"
alias vi="vim"
alias ls="lsd -AF --group-directories-first"
alias ll="lsd -Alh --group-directories-first --date=relative"
alias tree="lsd --tree"
alias cd="z"
alias cat="bat"

# Bundle aliases
alias rails="bundle exec rails"
alias rspec="bundle exec rspec"

# Working with the current working directory
alias pwr="cd ."
