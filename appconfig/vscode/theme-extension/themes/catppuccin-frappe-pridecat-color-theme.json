  "tokenColors": [
    {
      "name": "DEFAULT_KEYWORD",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#ca9ee6"
      }
    },
    {
      "name": "DEFAULT_OPERATION_SIGN",
      "scope": [
        "keyword.operator",
        "punctuation.operator"
      ],
      "settings": {
        "foreground": "#99d1db"
      }
    },
    {
      "name": "DEFAULT_STRING",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a6d189"
      }
    },
    {
      "name": "DEFAULT_VALID_STRING_ESCAPE",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#f4b8e4"
      }
    },
    {
      "name": "DEFAULT_INVALID_STRING_ESCAPE",
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#a6d189"
      }
    },
    {
      "name": "DEFAULT_NUMBER",
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#ef9f76"
      }
    },
    {
      "name": "DEFAULT_CONSTANT",
      "scope": [
        "constant.language",
        "constant.other",
        "variable.other.constant",
        "support.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#ef9f76"
      }
    },
    {
      "name": "DEFAULT_LINE_COMMENT",
      "scope": [
        "comment",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#737994",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_BLOCK_COMMENT",
      "scope": "comment.block",
      "settings": {
        "foreground": "#737994",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_DOC_COMMENT",
      "scope": "comment.block.documentation",
      "settings": {
        "foreground": "#737994",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_DOC_COMMENT_TAG",
      "scope": [
        "keyword.other.documentation",
        "storage.type.class.jsdoc",
        "comment.block.documentation keyword"
      ],
      "settings": {
        "foreground": "#e78284",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_DOC_COMMENT_TAG_VALUE",
      "scope": [
        "comment.block.documentation variable",
        "comment.block.documentation entity.name.type"
      ],
      "settings": {
        "foreground": "#c6d0f5"
      }
    },
    {
      "name": "DEFAULT_FUNCTION_DECLARATION",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#8caaee",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_FUNCTION_CALL",
      "scope": [
        "meta.function-call",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8caaee",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_CLASS_NAME",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#e5c890",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_CLASS_REFERENCE",
      "scope": [
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#e5c890"
      }
    },
    {
      "name": "DEFAULT_INTERFACE_NAME",
      "scope": [
        "entity.name.type.interface",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#e5c890",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_PARAMETER",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#ea999c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_LOCAL_VARIABLE",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#c6d0f5"
      }
    },
    {
      "name": "DEFAULT_INSTANCE_FIELD",
      "scope": [
        "variable.other.property",
        "variable.other.member",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#c6d0f5"
      }
    },
    {
      "name": "DEFAULT_STATIC_FIELD",
      "scope": [
        "variable.other.class",
        "variable.other.constant.property"
      ],
      "settings": {
        "foreground": "#81c8be"
      }
    },
    {
      "name": "DEFAULT_GLOBAL_VARIABLE",
      "scope": [
        "variable.other.global",
        "variable.language.global",
        "punctuation.definition.variable"
      ],
      "settings": {
        "foreground": "#ea999c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_PREDEFINED_SYMBOL",
      "scope": [
        "variable.language",
        "support.type.builtin",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#babbf1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_METADATA",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "meta.annotation",
        "support.type.annotation"
      ],
      "settings": {
        "foreground": "#e5c890",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEFAULT_LABEL",
      "scope": [
        "entity.name.label",
        "constant.other.label"
      ],
      "settings": {
        "foreground": "#c6d0f5"
      }
    },
    {
      "name": "DEFAULT_BRACES",
      "scope": [
        "punctuation.section",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "DEFAULT_BRACKETS",
      "scope": [
        "meta.brace.square",
        "punctuation.definition.array"
      ],
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "DEFAULT_PARENTHS",
      "scope": [
        "meta.brace.round",
        "punctuation.definition.parameters"
      ],
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "DEFAULT_COMMA",
      "scope": [
        "punctuation.separator",
        "punctuation.separator.comma"
      ],
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "DEFAULT_DOT",
      "scope": [
        "punctuation.accessor",
        "punctuation.delimiter"
      ],
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "DEFAULT_SEMICOLON",
      "scope": "punctuation.terminator",
      "settings": {
        "foreground": "#949cbb"
      }
    },
    {
      "name": "HTML_TAG_NAME",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8caaee"
      }
    },
    {
      "name": "HTML_ATTRIBUTE_NAME",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#e5c890"
      }
    },
    {
      "name": "CSS.PROPERTY_NAME",
      "scope": [
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#8caaee",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS.PROPERTY_VALUE",
      "scope": [
        "support.constant.property-value",
        "meta.property-value"
      ],
      "settings": {
        "foreground": "#e5c890"
      }
    },
    {
      "name": "CSS.TAG_NAME",
      "scope": "entity.name.tag.css",
      "settings": {
        "foreground": "#e5c890"
      }
    },
    {
      "name": "MARKDOWN_HEADER_LEVEL_1",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#e78284"
      }
    },
    {
      "name": "MARKDOWN_BOLD",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#e78284",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MARKDOWN_ITALIC",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#e78284",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DEPRECATED_ATTRIBUTES",
      "scope": "invalid.deprecated",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "TODO_DEFAULT_ATTRIBUTES",
      "scope": "comment keyword.todo",
      "settings": {
        "foreground": "#e5c890",
        "fontStyle": "italic"
      }
    }
  ]
}
