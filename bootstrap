#!/bin/zsh
#
# Modular bootstrap — sources every step under bootstrap.d/ and runs them in
# the order shown in `bootstrap()` below. Re-runnable (most steps are
# idempotent); pass a GitHub PAT on first run only.

if [ "$#" -ne 1 ] && [ ! -f "$HOME/.auth" ]; then
  echo "Usage: ./bootstrap <DOTFILES_GITHUB_PERSONAL_ACCESS_TOKEN>"
  exit 1
fi

DOTFILES_GITHUB_PERSONAL_ACCESS_TOKEN=$1
SETUP_HOMEBREW=false
DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# Source every step module
for step in "$DOTFILES_DIR"/bootstrap.d/*.sh; do
  source "$step"
done

bootstrap() {
  mkdir -p "$HOME/tmp"

  # Phase 1 — environment
  detect_platform
  configure_shell_options

  # Phase 2 — paths, secrets, symlinks
  make_workspace
  configure_paths
  configure_ssh
  install_fonts
  create_auth_dotfile
  symlink_dotfiles
  symlink_claude_config
  symlink_gh_config
  symlink_atuin_config
  make_user_bin

  # Phase 3 — platform packages
  if [ "$PLATFORM" = "wsl" ]; then
    copy_userprofile_files
    winget_install
    aptitude_install
    manual_install
    # configure_gpg
    configure_wsl_windows_crossover_paths
  elif [ "$PLATFORM" = "macos" ]; then
    install_xcode_cli
    install_rosetta
    install_homebrew
    install_homebrew_bundle
  fi

  # Phase 4 — universal (Mac App Store apps install via `brew bundle` now)
  pip_install
  set_default_shell

  # Phase 5 — macOS end caps
  if [ "$PLATFORM" = "macos" ]; then
    restore_user_defaults
  fi

  # Phase 6 — plugin managers / runtimes / agents
  configure_asdf
  install_tpm
  install_launch_agents
}

bootstrap
