#!/bin/zsh
# dotctor — health-check the dotfiles installation.
#
#   dotctor                Read-only audit. Exits 0 on success, 1 if any errors.
#   dotctor --fix          Apply safe auto-fixes (missing symlinks, .orig cleanup).
#   dotctor -h | --help    Show this help.
#
# Checks:
#   symlinks    — every tracked file/dir is symlinked into $HOME correctly
#   brewfile    — Brewfile in sync with installed taps/brews/casks/mas
#   asdf        — .tool-versions matches what's installed
#   auth        — ~/.auth present, mode 600, exports required vars
#   shell       — $SHELL is the configured target
#   repo        — working tree clean, no stray .orig/.rej files
#   secrets     — no plaintext private-key files lurking in the working tree

set -u

DOTFILES="${DOTFILES:-$HOME/.dotfiles}"
FIX=false

if [ -t 1 ]; then
  C_RED=$'\e[31m'; C_YELLOW=$'\e[33m'; C_GREEN=$'\e[32m'; C_DIM=$'\e[2m'; C_RESET=$'\e[0m'
else
  C_RED=''; C_YELLOW=''; C_GREEN=''; C_DIM=''; C_RESET=''
fi

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
  exit ${1:-0}
}

while [ $# -gt 0 ]; do
  case "$1" in
    --fix|-f)   FIX=true ;;
    --help|-h)  usage 0 ;;
    *)          echo "Unknown option: $1" >&2; usage 1 ;;
  esac
  shift
done

# ─── Result tracking ──────────────────────────────────────────────────────
typeset -A LABELS
typeset -a CHECK_ORDER
typeset -A STATES MESSAGES FIX_HINTS

result() {
  # result <check> <state: ok|warn|err> [message] [fix_hint]
  local check="$1" state="$2" msg="${3:-}" hint="${4:-}"
  STATES[$check]="$state"
  MESSAGES[$check]="$msg"
  [ -n "$hint" ] && FIX_HINTS[$check]="$hint"
}

run_check() {
  local check="$1" label="$2" fn="$3"
  CHECK_ORDER+=("$check")
  LABELS[$check]="$label"
  "$fn"
}

# ─── check: symlinks ──────────────────────────────────────────────────────
# Expected symlinks, mirroring bootstrap.d/60-symlinks.sh.

EXPECTED_SYMLINKS=()
# Top-level dotfiles, mirroring bootstrap.d/60-symlinks.sh `.^(gitignore|git|claude)`.
# .DS_Store is excluded because it's macOS Finder junk, not tracked config.
for src in "$DOTFILES"/.*; do
  name="${src##*/}"
  case "$name" in
    .|..|.git|.gitignore|.claude|.DS_Store) continue ;;
  esac
  EXPECTED_SYMLINKS+=("$HOME/$name|$src")
done
# _config subdirs, mirroring bootstrap.d/60-symlinks.sh `_config/^(gh|atuin)`.
for src in "$DOTFILES"/_config/*; do
  name="${src##*/}"
  case "$name" in
    gh|atuin) continue ;;
  esac
  EXPECTED_SYMLINKS+=("$HOME/.config/$name|$src")
done
# File-level entries — only include if the repo source exists.
for entry in \
  "$HOME/.claude/CLAUDE.md|$DOTFILES/.claude/CLAUDE.md" \
  "$HOME/.claude/settings.json|$DOTFILES/.claude/settings.json" \
  "$HOME/.claude/rules|$DOTFILES/.claude/rules" \
  "$HOME/.config/gh/config.yml|$DOTFILES/_config/gh/config.yml" \
  "$HOME/.config/atuin/config.toml|$DOTFILES/_config/atuin/config.toml"
do
  [ -e "${entry##*|}" ] && EXPECTED_SYMLINKS+=("$entry")
done

# True if a real file/dir at $1 is byte-identical to the repo source at $2
# (directories compared recursively, ignoring .DS_Store). Used to decide
# whether a conflict can be safely auto-replaced with a symlink.
_target_matches_source() {
  local target="$1" src="$2"
  if [ -d "$target" ] && [ -d "$src" ]; then
    diff -rq --exclude=.DS_Store "$target" "$src" >/dev/null 2>&1
  elif [ -f "$target" ] && [ -f "$src" ]; then
    cmp -s "$target" "$src"
  else
    return 1
  fi
}

check_symlinks() {
  local target src missing=0 mismatched=0 safe_conflict=0 drift_conflict=0 fixed=0
  local -a drift_targets
  for entry in "${EXPECTED_SYMLINKS[@]}"; do
    target="${entry%%|*}"
    src="${entry##*|}"

    # Already correctly linked.
    if [ -L "$target" ] && [ "$(readlink "$target")" = "$src" ]; then
      continue
    fi

    local action=""
    if [ -L "$target" ]; then
      action=relink; ((mismatched++))
    elif [ ! -e "$target" ]; then
      action=create; ((missing++))
    elif _target_matches_source "$target" "$src"; then
      action=replace; ((safe_conflict++))
    else
      ((drift_conflict++))
      drift_targets+=("${target/#$HOME/~}")
      continue  # never auto-fix drift — would clobber local changes
    fi

    if $FIX; then
      mkdir -p "$(dirname "$target")"
      [ "$action" = "replace" ] && rm -rf "$target"
      ln -sfn "$src" "$target" && ((fixed++))
    fi
  done

  local fixable=$((missing + mismatched + safe_conflict))
  if [ $((fixable + drift_conflict)) -eq 0 ]; then
    result symlinks ok "all ${#EXPECTED_SYMLINKS[@]} dotfile links healthy"
    return
  fi

  local parts=()
  [ $missing -gt 0 ]        && parts+=("$missing missing")
  [ $mismatched -gt 0 ]     && parts+=("$mismatched mismatched")
  [ $safe_conflict -gt 0 ]  && parts+=("$safe_conflict conflict")
  [ $drift_conflict -gt 0 ] && parts+=("$drift_conflict diverged")
  local msg="${(j:, :)parts}"
  [ $fixed -gt 0 ] && msg="$msg ($fixed auto-fixed)"

  if [ $drift_conflict -gt 0 ]; then
    local hint="reconcile then re-link: ${(j:, :)drift_targets}"
    if [ $fixable -gt 0 ] && ! $FIX; then
      hint="dotctor --fix; then $hint"
    fi
    result symlinks err "$msg" "$hint"
  elif $FIX; then
    if [ $fixed -eq $fixable ]; then
      result symlinks ok "fixed $fixed dotfile link(s)"
    else
      result symlinks warn "$msg"
    fi
  else
    result symlinks warn "$msg" "dotctor --fix"
  fi
}

# ─── check: mcp ───────────────────────────────────────────────────────────
# ~/.claude.json isn't symlinked (it mixes tracked mcpServers with machine
# state), so check drift between the tracked subset and the live file instead.
check_mcp() {
  local repo="$DOTFILES/.claude/mcp-servers.json"
  local live="$HOME/.claude.json"
  if [ ! -f "$repo" ]; then
    result mcp ok "no tracked MCP servers"
    return
  fi
  if ! command -v jq >/dev/null; then
    result mcp warn "jq not installed — cannot check MCP server drift"
    return
  fi
  if [ ! -f "$live" ]; then
    result mcp warn "~/.claude.json not found"
    return
  fi

  local n_tracked drift=0 uncaptured
  n_tracked=$(jq -r '. | keys | length' "$repo")
  # The live mcpServers restricted to the keys the repo tracks, normalised the
  # same way as the repo file — drift if these differ.
  local repo_norm live_subset
  repo_norm=$(jq -S '.' "$repo")
  live_subset=$(jq -S --slurpfile r "$repo" \
    '(.mcpServers // {}) | with_entries(select(.key as $k | $r[0] | has($k)))' "$live")
  [ "$repo_norm" != "$live_subset" ] && drift=1
  # Servers configured live (user scope) but not yet captured in the repo.
  uncaptured=$(jq --slurpfile r "$repo" \
    '((.mcpServers // {}) | keys) - ($r[0] | keys) | length' "$live")

  if [ "$drift" -eq 0 ] && [ "$uncaptured" -eq 0 ]; then
    result mcp ok "$n_tracked tracked MCP server(s) in sync"
    return
  fi
  local parts=()
  [ "$drift" -ne 0 ]       && parts+=("tracked servers differ from ~/.claude.json")
  [ "$uncaptured" -gt 0 ]  && parts+=("$uncaptured live server(s) not captured")
  result mcp warn "${(j:; :)parts}" \
    "re-extract: jq -S '.mcpServers' ~/.claude.json > $repo  ·  restore: re-run ./bootstrap"
}

# ─── check: brewfile ──────────────────────────────────────────────────────
check_brewfile() {
  if [ "$(uname)" != "Darwin" ]; then
    result brewfile ok "skipped (not macOS)"
    return
  fi
  if ! command -v brew >/dev/null; then
    result brewfile err "brew not installed"
    return
  fi
  local out rc
  out=$(cd "$DOTFILES" && brew bundle check --verbose --file Brewfile 2>&1); rc=$?
  if [ $rc -eq 0 ]; then
    result brewfile ok "Brewfile in sync"
  else
    # Lines like "Casks not installed: foo, bar" or "X dependencies need to be installed."
    local summary
    summary=$(echo "$out" | grep -E 'not installed|need to be installed' | head -3 | tr '\n' ';' | sed 's/;$//')
    result brewfile warn "${summary:-Brewfile drift detected}" "cd $DOTFILES && brew bundle"
  fi
}

# ─── check: asdf ──────────────────────────────────────────────────────────
check_asdf() {
  if ! command -v asdf >/dev/null; then
    result asdf err "asdf not installed"
    return
  fi
  local versions_file="$DOTFILES/.tool-versions"
  [ -f "$versions_file" ] || { result asdf warn "no .tool-versions"; return; }

  local mismatches=()
  while IFS=' ' read -r tool version _; do
    [ -z "$tool" ] && continue
    [[ "$tool" == \#* ]] && continue
    if ! asdf where "$tool" "$version" >/dev/null 2>&1; then
      mismatches+=("$tool $version")
    fi
  done < "$versions_file"

  if [ ${#mismatches[@]} -eq 0 ]; then
    result asdf ok "all .tool-versions installed"
  else
    result asdf err "${#mismatches[@]} tool(s) not installed at the pinned version: ${mismatches[*]}" "cd $DOTFILES && asdf install"
  fi
}

# ─── check: auth ──────────────────────────────────────────────────────────
check_auth() {
  local auth="$HOME/.auth"
  if [ ! -f "$auth" ]; then
    result auth err "~/.auth does not exist" "./bootstrap <GH_TOKEN>"
    return
  fi
  local mode
  mode=$(stat -f '%Lp' "$auth" 2>/dev/null || stat -c '%a' "$auth" 2>/dev/null)
  local issues=()
  [ "$mode" != "600" ] && issues+=("mode is $mode (expect 600)")
  for var in HOMEBREW_GITHUB_API_TOKEN ZIPLINE_TOKEN; do
    grep -q "^export $var=" "$auth" || issues+=("missing export $var")
  done
  if [ ${#issues[@]} -eq 0 ]; then
    result auth ok "present, mode 600, required vars exported"
  else
    result auth warn "${(j:; :)issues}" "chmod 600 ~/.auth; edit to add missing exports"
  fi
}

# ─── check: shell ─────────────────────────────────────────────────────────
check_shell() {
  local expected
  case "$(uname)" in
    Darwin) expected="/opt/homebrew/bin/zsh" ;;
    Linux)  expected="/usr/bin/zsh" ;;
    *)      result shell warn "unknown platform: $(uname)"; return ;;
  esac
  local actual
  actual=$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')
  [ -z "$actual" ] && actual="$SHELL"
  if [ "$actual" = "$expected" ]; then
    result shell ok "default shell is $expected"
  else
    result shell warn "default shell is $actual, expected $expected" "sudo dscl . -create /Users/$USER UserShell $expected"
  fi
}

# ─── check: repo ──────────────────────────────────────────────────────────
check_repo() {
  local issues=()

  # Stray .orig / .rej files
  local stray
  stray=$(find "$DOTFILES" -type f \( -name '*.orig' -o -name '*.rej' \) -not -path '*/.git/*' 2>/dev/null)
  if [ -n "$stray" ]; then
    local n=$(echo "$stray" | wc -l | tr -d ' ')
    issues+=("$n stray .orig/.rej file(s)")
    if $FIX; then
      echo "$stray" | xargs rm -f
    fi
  fi

  # Working tree status
  if ! git -C "$DOTFILES" diff --quiet || ! git -C "$DOTFILES" diff --cached --quiet; then
    local n=$(git -C "$DOTFILES" status --porcelain | wc -l | tr -d ' ')
    issues+=("$n uncommitted change(s)")
  fi

  if [ ${#issues[@]} -eq 0 ]; then
    result repo ok "working tree clean"
  else
    result repo warn "${(j:; :)issues}" "cd $DOTFILES; review with 'git status'"
  fi
}

# ─── check: secrets-in-tree (informational warning) ───────────────────────
check_secrets() {
  local found=()
  while IFS= read -r f; do
    found+=("$f")
  done < <(find "$DOTFILES" \
    \( -name '*.key' -o -name 'id_rsa' -o -name 'id_ed25519' -o -name 'credentials' -o -name 'credentials.json' \) \
    -not -path '*/.git/*' \
    -not -path '*/node_modules/*' 2>/dev/null)

  if [ ${#found[@]} -eq 0 ]; then
    result secrets ok "no private-key files in working tree"
  else
    local n=${#found[@]}
    # Are they gitignored?
    local all_ignored=true
    for f in "${found[@]}"; do
      git -C "$DOTFILES" check-ignore -q "$f" 2>/dev/null || all_ignored=false
    done
    if $all_ignored; then
      result secrets warn "$n secret-like file(s) in tree (gitignored — defense-in-depth signal only)"
    else
      result secrets err "$n secret-like file(s) present and NOT gitignored — investigate before next git add"
    fi
  fi
}

# ─── Run all ──────────────────────────────────────────────────────────────
run_check symlinks "symlinks"     check_symlinks
run_check mcp      "mcp servers"  check_mcp
run_check brewfile "brewfile"     check_brewfile
run_check asdf     "asdf"         check_asdf
run_check auth     "auth file"    check_auth
run_check shell    "shell"        check_shell
run_check repo     "repo"         check_repo
run_check secrets  "secrets"      check_secrets

# ─── Render report ────────────────────────────────────────────────────────
n_ok=0; n_warn=0; n_err=0
for check in "${CHECK_ORDER[@]}"; do
  state="${STATES[$check]}"
  label="${(r:18:)LABELS[$check]}"
  msg="${MESSAGES[$check]:-}"
  hint="${FIX_HINTS[$check]:-}"
  case "$state" in
    ok)
      echo "${C_GREEN}✓${C_RESET} $label  $msg"
      ((n_ok++))
      ;;
    warn)
      echo "${C_YELLOW}⚠${C_RESET} $label  $msg"
      [ -n "$hint" ] && echo "${C_DIM}                   → $hint${C_RESET}"
      ((n_warn++))
      ;;
    err)
      echo "${C_RED}✗${C_RESET} $label  $msg"
      [ -n "$hint" ] && echo "${C_DIM}                   → $hint${C_RESET}"
      ((n_err++))
      ;;
  esac
done

echo
echo "${C_GREEN}$n_ok ok${C_RESET} · ${C_YELLOW}$n_warn warn${C_RESET} · ${C_RED}$n_err error${C_RESET}"

if ! $FIX && [ $n_warn -gt 0 ]; then
  echo "${C_DIM}Run 'dotctor --fix' to auto-apply safe fixes.${C_RESET}"
fi

[ $n_err -eq 0 ] && exit 0 || exit 1
