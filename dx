#!/bin/bash
# name: dx
# author: Wil Hall
# email: wil@wilhall.com

READBACK=true

usage()
{
cat << EOF
usage: $(basename $0)  

This utility performs backups and restorations of macOS user defaults.
Backups are managed in '~/.defaults/'.

OPTIONS:
   -h | --help        Show this message
   -r | --restore     <DOMAIN> The domain to restore
   -R | --restore-all Restore all domains that have backups
   -b | --backup      <DOMAIN> The domain to back up
   -B | --backup-all  Back up all domains that already have backups

<DOMAIN> is one of:
-globalDomain  The macOS global domain
<DOMAIN_NAME>  The fully-qualified domain name (e.g. application bundle identifier)
<APP_NAME>     The application name (e.g. '/Applications/<APP_NAME>.app'

EOF
}

resolve_domain() {
  if [[ "$1" == *'.'* ]] || [[ "$1" == '-globalDomain' ]]; then
    echo "$1"
  else
    GLOBAL_APP_LOCATION="/Applications/$1.app"
    USER_APP_LOCATION="$HOME/Applications/$1.app"
    SYSTEM_APP_LOCATION="/System/Applications/$1.app"
    CORE_SERVICES_APP_LOCATION="/System/Library/CoreServices/$1.app"
    if [ -d "$GLOBAL_APP_LOCATION" ]; then
      echo "$(mdls -name kMDItemCFBundleIdentifier -r "$GLOBAL_APP_LOCATION")"
    elif [ -d "$USER_APP_LOCATION" ]; then
      echo "$(mdls -name kMDItemCFBundleIdentifier -r "$USER_APP_LOCATION")"
    elif [ -d "$SYSTEM_APP_LOCATION" ]; then
      echo "$(mdls -name kMDItemCFBundleIdentifier -r "$SYSTEM_APP_LOCATION")"
    elif [ -d "$CORE_SERVICES_APP_LOCATION" ]; then
      echo "$(mdls -name kMDItemCFBundleIdentifier -r "$CORE_SERVICES_APP_LOCATION")"
    else
      echo "$SYSTEM_APP_LOCATION" 1>&2
      echo "Unable to resolve domain for app named '$1'" 1>&2
      return 1
    fi
  fi
}

backup() {
  BACKUP_FILE="$HOME/.defaults/$1.plist"
  mkdir -p "$HOME/.defaults"
  defaults export "$1" "$BACKUP_FILE" && plutil -convert xml1 "$BACKUP_FILE"
  if [[ $? == 0 ]]; then
    apply_filter "$1" "$BACKUP_FILE"
    if is_empty_plist "$BACKUP_FILE"; then
      rm -f "$BACKUP_FILE"
      echo "Skipped backup of '$1' — empty after filtering"
    else
      echo "Exported domain '$1' to $BACKUP_FILE"
      if [ "$READBACK" = true ]; then plutil -p "$BACKUP_FILE"; fi
    fi
  else
    echo "Failed to export domain '$1'"
    exit 1
  fi
}

# True (exit 0) when the plist contains no top-level entries — i.e. there is
# nothing left to restore. Used after apply_filter to suppress backups whose
# content has been entirely scrubbed.
is_empty_plist() {
  /usr/bin/python3 -c '
import plistlib, sys
with open(sys.argv[1], "rb") as fh:
    data = plistlib.load(fh)
if (isinstance(data, dict) and not data) or (isinstance(data, list) and not data):
    sys.exit(0)
sys.exit(1)
' "$1"
}

# Strip PII / machine-specific keys from a backed-up plist.
#
# Filters live in ~/.defaults/.filters/:
#   _global       — applied to every domain
#   <domain>      — applied only to that domain (e.g. com.apple.mail)
#
# Filter file format (one entry per line, blank lines and `#` comments ignored):
#   AccountOrdering              — literal KVC path from root (dot-separated)
#   ~^NSWindow Frame .*$         — `~`-prefix marks a Python regex that
#                                  matches keys by name at ANY depth
#
# Literals are precise; patterns walk the whole plist tree. Missing keys are
# silently skipped, so filters can be over-specified safely.
apply_filter() {
  local domain="$1"
  local backup_file="$2"
  local filter_dir="$HOME/.defaults/.filters"

  for f in "$filter_dir/_global" "$filter_dir/$domain"; do
    [ -f "$f" ] || continue
    local stripped_this
    stripped_this=$(/usr/bin/python3 - "$backup_file" "$f" <<'PY'
import plistlib, re, sys

plist_path, filter_path = sys.argv[1], sys.argv[2]
literals, patterns = [], []
with open(filter_path) as fh:
    for line in fh:
        s = line.split("#", 1)[0].strip()
        if not s:
            continue
        if s.startswith("~"):
            patterns.append(re.compile(s[1:]))
        else:
            literals.append(s)

with open(plist_path, "rb") as fh:
    data = plistlib.load(fh)

removed = 0

# Literals: dotted KVC paths from root.
for lit in literals:
    parts = lit.split(".")
    node = data
    try:
        for p in parts[:-1]:
            node = node[p]
        if isinstance(node, dict) and parts[-1] in node:
            del node[parts[-1]]
            removed += 1
    except (KeyError, TypeError):
        pass

# Patterns: regex against key name at any depth (anchored / fullmatch).
def strip(node):
    global removed
    if isinstance(node, dict):
        for key in list(node.keys()):
            if any(p.fullmatch(key) for p in patterns):
                del node[key]
                removed += 1
            else:
                strip(node[key])
    elif isinstance(node, list):
        for item in node:
            strip(item)

if patterns:
    strip(data)

with open(plist_path, "wb") as fh:
    plistlib.dump(data, fh)

print(removed)
PY
)
    if [ "${stripped_this:-0}" -gt 0 ]; then
      echo "  filter $(basename "$f"): stripped $stripped_this key(s)"
    fi
  done

  # Re-emit as XML so the committed file stays text-diffable.
  plutil -convert xml1 "$backup_file"
}

restore() {
  if [ ! -f "$HOME/.defaults/$1.plist" ]; then
    echo "No backup exists for the domain '$1'"
    exit 1
  fi
  defaults import "$1" "$HOME/.defaults/$1.plist"
  if [[ $? == 0 ]]; then
    echo "Imported domain '$1'"
    if [ "$READBACK" = true ]; then defaults read $1; fi
  else
    echo "Failed to import domain '$1'"
    exit 1
  fi
}

backup_all() {
  READBACK=false
  for BACKUP_FILE in $HOME/.defaults/*.plist; do
    DOMAIN="$(basename "$BACKUP_FILE" .plist)"
    backup "$DOMAIN"
  done
}

restore_all() {
  READBACK=false
  for BACKUP_FILE in $HOME/.defaults/*.plist; do
    DOMAIN="$(basename "$BACKUP_FILE" .plist)"
    restore "$DOMAIN"
  done
}

while [ ! $# -eq 0 ]; do
    case "$1" in
        -r | --restore)
            if [ "$2" ]; then
                DOMAIN="$(resolve_domain "$2")"
                if [[ $? != 0 ]]; then exit 1; fi
                restore "$DOMAIN"
                exit
            else
                echo '--restore requires a DOMAIN'
                exit 1
            fi
            ;;
        -b | --backup)
            if [ "$2" ]; then
                OPERATION='backup'
                DOMAIN="$(resolve_domain "$2")"
                if [[ $? != 0 ]]; then exit 1; fi
                backup "$DOMAIN"
                exit
            else
                echo '--backup requires a DOMAIN'
                exit 1
            fi
            ;;
        -R | --restore-all)
            restore_all
            exit
            ;;
        -B | --backup-all)
            backup_all
            exit
            ;;
        -h | --help)
            usage
            exit
            ;;
        *)
            usage
            exit
            ;;
    esac
    shift
done

usage
